{
"update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "name": "Todoist Custom Sidebar",
  "icons": {
      "16": "sidebar2.png",
      "32": "sidebar2.png",
      "48": "sidebar2.png",
      "128": "sidebar2.png"
    },
  "version": "2.6",
  "description": "Native sidebar using Todoist API.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://api.todoist.com/*"
  ],
  "action": {
    "default_title": "Toggle Tasks",
    "default_icon": {
      "16": "sidebar2.png",
      "32": "sidebar2.png",
      "48": "sidebar2.png",
      "128": "sidebar2.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["styles.css", "icon.svg"],
      "matches": ["<all_urls>"]
    }
  ]
}